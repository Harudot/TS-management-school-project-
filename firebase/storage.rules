rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() { return request.auth != null; }
    function isAdmin() {
      return signedIn() && request.auth.token.role == 'admin';
    }

    // Public-read building assets, admin-write
    match /buildings/{buildingId}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // Public-read people photos, admin-write
    match /people/{personId}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    // Per-user profile photos
    match /users/{uid}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == uid;
    }
  }
}
